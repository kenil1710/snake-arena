# Copy to .env.local and fill in. All values are public (NEXT_PUBLIC_*).

# Contract addresses (Base Sepolia)
NEXT_PUBLIC_SNAKE_ARENA_ADDRESS=
NEXT_PUBLIC_POWERUP_STORE_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_CHAIN_ID=84532
# Base Sepolia RPC for all browser reads + on-chain event scans. The public URL
# works but rate-limits eth_getLogs aggressively, which breaks the profile /
# leaderboard history scans. Use a dedicated provider key in that format:
#   NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Game backend (apps/backend)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Block SnakeArena was deployed at (lower bound for event scans)
NEXT_PUBLIC_DEPLOY_BLOCK=42674891

# Optional: OnchainKit API key from the Coinbase Developer Platform
NEXT_PUBLIC_ONCHAINKIT_API_KEY=
