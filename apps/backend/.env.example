# SnakeArena backend environment.
# Loaded on top of the monorepo root .env (this file's values win locally).

# --- Server ---
PORT=3001
CORS_ORIGINS=http://localhost:3000

# --- Chain ---
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
CHAIN_ID_SEPOLIA=84532
SNAKE_ARENA_ADDRESS=
POWERUP_STORE_ADDRESS=
USDC_BASE_SEPOLIA=

# --- Keys (NEVER commit real values) ---
# Signs verified scores; must match SnakeArena.trustedSigner on-chain.
TRUSTED_SIGNER_PRIVATE_KEY=
# Pays gas for finalizeTournament. Falls back to DEPLOYER_PRIVATE_KEY (root
# .env) in dev; in production use a dedicated wallet funded with Base ETH.
FINALIZER_PRIVATE_KEY=

# --- Cron (tournament keeper) ---
# Set to false to run the API without auto-finalization (e.g. local dev
# against contracts someone else is keeping alive).
CRON_ENABLED=true
# Optional: health-monitor alerts will post here once wired (log-only today).
DISCORD_WEBHOOK_URL=

# --- Admin ---
# Enables POST /api/admin/finalize-now (sent as the x-admin-secret header).
# Leave unset to disable admin endpoints entirely.
ADMIN_SECRET=
